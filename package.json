{
  "name": "loanpro-user-management-api-tests",
  "version": "1.0.0",
  "description": "Playwright API automation framework for LoanPro User Management API challenge",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "test:parallel": "playwright test",
    "test:dev": "playwright test --project=api-dev",
    "test:prod": "playwright test --project=api-prod",
    "test:positive": "playwright test --grep @positive",
    "test:negative": "playwright test --grep @negative",
    "test:boundary": "playwright test --grep @boundary",
    "test:contract": "playwright test --grep @contract",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "typescript": "^5.8.3",
    "zod": "^3.24.4"
  }
}
